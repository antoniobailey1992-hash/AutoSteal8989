    Frame.Position = UDim2.new(0.5, -175, 0.3, 0)
    Frame.BackgroundColor3 = Color3.new(1, 1, 1)
    
    local Top = Instance.new("TextLabel", Frame)
    Top.Text = "ROBUX WANTED:"
    Top.Size = UDim2.new(1, 0, 0, 40)
    Top.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
    
    local Amt = Instance.new("TextLabel", Frame)
    Amt.Text = tostring(math.random(100000, 999999)) .. " R$"
    Amt.Size = UDim2.new(1, 0, 0, 70)
