-- STEALER TAB
local Steal = Window:NewTab("Stealer")
local SSec = Steal:NewSection("Roof Drop System")

SSec:NewButton("1. Set Roof Target", "Stand on roof above pad", function()
    if not IsUnlocked then return end
    _G.RoofPos = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
end)

SSec:NewToggle("2. Active Snatch", "Teleports items to drop point", function(state)
    if not IsUnlocked then return end
    _G.Snatching = state
    while _G.Snatching do
        task.wait(0.4)
        for _, v in pairs(game.Workspace:GetChildren()) do
            if v:IsA("Model") and (v.Name:find("Brainrot") or v.Name:find("Item")) then
                local p = v.PrimaryPart or v:FindFirstChild("Handle")
                if p and _G.RoofPos then p.CFrame = _G.RoofPos end
            end
        end
    end
end)

-- SHOP TROLL TAB
local Shop = Window:NewTab("Live Shop")
local LSec = Shop:NewSection("Fake Gifting UI")

local function ShowFakeRobuxBox()
    -- Creates the little box you asked for
    local ScreenGui = Instance.new("ScreenGui", game.Players.LocalPlayer.PlayerGui)
    local Frame = Instance.new("Frame", ScreenGui)
    local Label = Instance.new("TextLabel", Frame)
    local Amount = Instance.new("TextLabel", Frame)
    
    Frame.Size = UDim2.new(0, 200, 0, 100)
    Frame.Position = UDim2.new(0.5, -100, 0.4, -50)
    Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Frame.BorderSizePixel = 2
    
    Label.Text = "Robux Amount:"
    Label.Size = UDim2.new(1, 0, 0, 30)
    Label.TextColor3 = Color3.new(1, 1, 1)
    Label.BackgroundTransparency = 1
    
    Amount.Text = tostring(math.random(50000, 1000000)) .. " R$"
    Amount.Size = UDim2.new(1, 0, 0, 50)
    Amount.Position = UDim2.new(0, 0, 0, 40)
    Amount.TextColor3 = Color3.fromRGB(0, 255, 100)
    Amount.TextSize = 25
    Amount.BackgroundTransparency = 1
    
    task.wait(3) -- Disappears after 3 seconds
    ScreenGui:Destroy()
end

